# Frontend Environment Variables
# Set this to your deployed backend URL on Render.com
VITE_API_BASE_URL=http://localhost:8000

# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
# Alternatively (NEXT.js-style names supported via Vite envPrefix)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Backend Environment Variables
DATABASE_URL=sqlite:///./data/virtual_mirror.db
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENVIRONMENT=development
MAX_UPLOAD_SIZE=10485760
TTS_ENABLED=true

# Optional: If using external database
# DATABASE_URL=postgresql://user:password@localhost:5432/virtual_mirror
# DATABASE_URL=mysql://user:password@localhost:3306/virtual_mirror

# Optional: API Keys
# OPENAI_API_KEY=your_api_key_here
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
